# This is your Caddy configuration. This default config
# opens a port and serves a static site from the www folder.
# Edit this file according to your needs.

:8080 {

    handle /api/* {
        reverse_proxy api.railway.internal:4000 {
            transport http {
                dial_timeout 30s
                response_header_timeout 120s
            }
        }
    }

    handle {
        reverse_proxy web.railway.internal:8080 {
            transport http {
                dial_timeout 30s
                response_header_timeout 120s
            }
        }
    }

}
